# Model Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Why MiniLM-L6-v2?
# - 384 dimensions: small enough to be fast, large enough to capture nuance
# - Trained specifically for semantic similarity tasks
# - Runs well on CPU — no GPU required
# - 6-layer version is the sweet spot of speed vs quality

# Clustering
N_CLUSTERS=16
# We'll justify this number in clustering/fuzzy_cluster.py
# Short answer: 20 newsgroup categories collapse into ~16 semantic themes
# because several categories overlap heavily (e.g., sci.med + sci.space share vocabulary)

# Cache
BASE_SIMILARITY_THRESHOLD=0.75
# This is the most important tunable in the system.
# At 0.82: catches paraphrased queries, rarely gives false hits.
# We explore the full tradeoff in experiments/threshold_experiment.ipynb

# Paths
DATA_DIR=data
MODELS_DIR=models
INDEX_PATH=models/faiss.index
CLUSTER_MODEL_PATH=models/cluster_model.pkl
EMBEDDINGS_PATH=models/embeddings.npy
METADATA_PATH=models/metadata.pkl